{
  "manifest_version": 3,
  "name": "Brain Lock",
  "version": "1.1",
  "description": "Answer a question correctly to unlock your browser",
  "permissions": ["storage", "tabs", "alarms", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["lock.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["questions.json"],
      "matches": ["<all_urls>"]
    }
  ]
}